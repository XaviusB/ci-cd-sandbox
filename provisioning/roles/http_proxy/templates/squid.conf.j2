# Ansible managed - Squid HTTP Proxy Configuration
# HTTP port
http_port {{ squid_port }}

# Access Control Lists
{% for network in squid_local_networks %}
acl localnet src {{ network }}
{% endfor %}

acl k8s_api dstdomain {{ squid_k8s_api_domain }}

{% for port in squid_ssl_ports %}
acl SSL_ports port {{ port }}
{% endfor %}

{% for port in squid_safe_ports %}
acl Safe_ports port {{ port }}
{% endfor %}

acl CONNECT method CONNECT

# Allow rules
http_access allow localhost manager
http_access deny manager
http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports
http_access allow CONNECT k8s_api
http_access allow localnet
http_access allow localhost
http_access deny all

# Logging
access_log {{ squid_access_log }}
cache_log {{ squid_cache_log }}
logfile_rotate {{ squid_logfile_rotate }}

# Memory cache
cache_mem {{ squid_cache_mem }}
maximum_object_size_in_memory {{ squid_max_object_size_in_memory }}

# Disk cache
cache_dir {{ squid_cache_dir }}
maximum_object_size {{ squid_max_object_size }}

# Performance tuning
workers {{ squid_workers }}
max_filedescriptors {{ squid_max_filedescriptors }}

# DNS
dns_nameservers {{ squid_dns_nameservers }}

# Refresh patterns
refresh_pattern ^ftp:           1440    20%     10080
refresh_pattern ^gopher:        1440    0%      1440
refresh_pattern -i (/cgi-bin/|\?) 0     0%      0
refresh_pattern .               0       20%     4320
