APP_NAME = Gitea: because GitLab is too fat and GitHub too mainstream
RUN_USER = {{ gitea_user }}
WORK_PATH = {{ gitea_data_dir }}
RUN_MODE = prod

[database]
DB_TYPE = {{ gitea_db_type }}
HOST = {{ gitea_db_host }}
NAME = {{ gitea_db_name }}
USER = {{ gitea_db_user }}
PASSWD = {{ gitea_db_password }}
SSL_MODE = disable
SCHEMA =
PATH = {{ gitea_data_dir }}/data/gitea.db
LOG_SQL = false

[repository]
ROOT = {{ gitea_repository_root }}

[server]
SSH_DOMAIN = {{ gitea_domain }}
DOMAIN = {{ gitea_domain }}
HTTP_PORT = {{ gitea_http_port }}
HTTP_ADDR = {{ gitea_http_addr }}

ROOT_URL = {{ gitea_root_url }}
APP_DATA_PATH = {{ gitea_data_dir }}/data
DISABLE_SSH = {{ gitea_disable_ssh | lower }}
SSH_PORT = {{ gitea_ssh_port }}
LFS_START_SERVER = {{ gitea_lfs_enabled | lower }}
LFS_JWT_SECRET = {{ gitea_lfs_jwt_secret }}
OFFLINE_MODE = true
START_SSH_SERVER = {{ gitea_start_ssh_server | lower }}

[lfs]
PATH = {{ gitea_lfs_path }}

[mailer]
ENABLED = false

[service]
REGISTER_EMAIL_CONFIRM = {{ gitea_register_email_confirm | lower }}
ENABLE_NOTIFY_MAIL = {{ gitea_enable_notify_mail | lower }}
DISABLE_REGISTRATION = {{ gitea_disable_registration | lower }}
EMAIL_DOMAIN_ALLOWLIST = {{ gitea_email_domain_allowlist }}
REGISTER_MANUAL_CONFIRM = {{ gitea_register_manual_confirm | lower }}
ALLOW_ONLY_EXTERNAL_REGISTRATION = false
ENABLE_CAPTCHA = {{ gitea_enable_captcha | lower }}
REQUIRE_SIGNIN_VIEW = {{ gitea_require_signin_view | lower }}
DEFAULT_KEEP_EMAIL_PRIVATE = false
DEFAULT_ALLOW_CREATE_ORGANIZATION = false
DEFAULT_ENABLE_TIMETRACKING = true
NO_REPLY_ADDRESS = noreply.localhost
CAPTCHA_TYPE = image

[openid]
ENABLE_OPENID_SIGNIN = true
ENABLE_OPENID_SIGNUP = true

[cron.update_checker]
ENABLED = false

[session]
PROVIDER = file

[log]
MODE = console
LEVEL = info
ROOT_PATH = {{ gitea_data_dir }}/log

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = committer

[security]
INSTALL_LOCK = true
INTERNAL_TOKEN = {{ gitea_internal_token }}
PASSWORD_HASH_ALGO = {{ gitea_password_hash_algo }}

[oauth2]
JWT_SECRET = {{ gitea_oauth2_jwt_secret }}

[ui.meta]
AUTHOR = Xavier Bourdeau
DESCRIPTION = This server is your CI/CD lifeline for the year. Break it, and you'll be manually deploying code with carrier pigeons and USB sticks.
KEYWORDS = go,git,self-hosted,gitea

[i18n]
LANGS = en-US
NAMES = English
